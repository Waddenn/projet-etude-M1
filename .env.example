# Copier vers .env à la racine (chargé automatiquement par `just`).
# Ne jamais committer de secrets réels.

# Dossier des clés dev-side (ssh-deploy-key, tailscale-authkey, host-keys/)
# SECRETS_DIR=./secrets

# Clé SSH pour nixos-anywhere / nixos-rebuild / just cp|w1|w2
# PROJET_K3S_KEY=./secrets/ssh-deploy-key

# Pre-auth key Tailscale (injectée au premier boot des VMs)
# TS_AUTH_KEY_FILE=./secrets/tailscale-authkey

# Kubeconfig local récupéré depuis cp-1
# KUBECONFIG=$HOME/.kube/projet-etude
